generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StatusProduto {
  EM_ESTOQUE
  VENDIDO
}

model Produto {
  id          Int           @id @default(autoincrement())
  nome        String
  descricao   String?
  categoria   String
  fotoUrl     String?
  precoCompra Decimal
  precoVenda  Decimal
  status      StatusProduto @default(EM_ESTOQUE)
  usuarioId   Int
  usuario     Usuario       @relation(fields: [usuarioId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  vendidoEm   DateTime?
}

model Usuario {
  id        Int       @id @default(autoincrement())
  nome      String
  email     String    @unique
  senha     String
  produtos  Produto[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}
